<svg width="800" height="600" viewBox="0 0 800 600" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="mirror" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e3f2fd;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#ffffff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e3f2fd;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="#f5f5f5"/>
  <ellipse cx="400" cy="300" rx="200" ry="250" fill="url(#mirror)" opacity="0.8"/>
  <text x="400" y="560" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="#546E7A" text-anchor="middle">MIRROR</text>
</svg>
